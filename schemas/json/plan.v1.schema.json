{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.buildtovalue.dev/schemas/plan.v1.schema.json",
  "title": "plan.v1",
  "description": "Manifesto de plano/entrega da esteira BuildToValue: fases → entregas exportáveis (DOCX/XLSX/PDF/MusicXML) → quality gates → critérios de sucesso → orçamento → rollback. Ponte entre o grafo do squad (squad.workflow.v1) e os artefatos que são o produto.",
  "type": "object",
  "required": ["execution_sequence", "budget"],
  "properties": {
    "prerequisites": {
      "type": "object",
      "properties": {
        "contracts": { "type": "array", "items": { "type": "string" } },
        "approvals": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "execution_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "primary_role", "approval_required", "estimated_confidence"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "primary_role": { "type": "string" },
          "support_roles": { "type": "array", "items": { "type": "string" } },
          "deliverables": { "type": "array", "items": { "type": "string" } },
          "approval_required": { "type": "boolean" },
          "estimated_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "quality_gates": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "properties": {
        "functional": { "type": "array", "items": { "type": "string" } },
        "non_functional": { "type": "array", "items": { "type": "string" } }
      }
    },
    "budget": {
      "type": "object",
      "required": ["estimated_cost", "max_llm_calls"],
      "properties": {
        "estimated_cost": { "type": "number", "minimum": 0 },
        "max_llm_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "rollback_strategy": {
      "type": "object",
      "properties": {
        "kill_switch": { "type": "boolean" }
      }
    }
  }
}
