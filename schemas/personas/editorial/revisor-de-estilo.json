  "activation_triggers": {
    "semantic_patterns": ["revisar", "clareza", "estilo"],
    "context_keywords": ["texto", "artigo"],
    "confidence_threshold": 0.6
  },
  "communication": {
    "receives_from": ["redator"],
    "delivers_to": ["fact-checker"],
    "handoff_contract": "artigo revisado + notas de estilo"
  },
  "delivery_formats": ["DOCX", "Markdown", "HTML"]
